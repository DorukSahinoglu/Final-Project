{
  "name": "pulseroute-desktop",
  "private": true,
  "version": "0.0.1",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:frontend\" \"npm:dev:backend\" \"npm:dev:electron\"",
    "dev:frontend": "npm --prefix ../frontend run dev -- --host 127.0.0.1 --port 5173",
    "dev:backend": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000 --app-dir ../backend",
    "dev:electron": "wait-on tcp:5173 tcp:8000 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron ./electron/main.cjs"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.3.1",
    "wait-on": "^8.0.3"
  }
}
