from typing import List, Dict, Set, Hashable
import random

Chromosome = List[int]
EdgeTable = Dict[int, Set[int]]
StrongEdges = Dict[int, Set[int]]




def swap_mutation(chrom: list[int], mutation_rate: float) -> None:
    if random.random() < mutation_rate:
        n = len(chrom)
        i, j = random.sample(range(n), 2)
        chrom[i], chrom[j] = chrom[j], chrom[i]


def build_edge_table(p1: Chromosome, p2: Chromosome) -> tuple[EdgeTable, StrongEdges]:
    def neighbors(chrom: Chromosome) -> Dict[int, Set[int]]:
        n = len(chrom)
        neigh: Dict[int, Set[int]] = {gene: set() for gene in chrom}
        for i, gene in enumerate(chrom):
            left_gene = chrom[(i - 1) % n]
            right_gene = chrom[(i + 1) % n]
            neigh[gene].add(left_gene)
            neigh[gene].add(right_gene)
        return neigh

    n1 = neighbors(p1)
    n2 = neighbors(p2)

    edges: EdgeTable = {}
    strong: StrongEdges = {}

    for gene in p1:
        all_neigh = n1[gene] | n2[gene]
        edges[gene] = set(all_neigh)

        strong_neigh = n1[gene] & n2[gene]
        strong[gene] = set(strong_neigh)

    return edges, strong


def choose_start_node(edges: Dict[int, Set[int]]) -> int:
 
    return min(edges.keys(), key=lambda gene: (len(edges[gene]), gene))


def choose_next_node(current: int,
                     edges: Dict[int, Set[int]],
                     strong_edges: Dict[int, Set[int]]) -> int | None:

    neighbors = edges[current]
    if not neighbors:
        return None

    strong_neighbors = strong_edges[current] & neighbors
    if strong_neighbors:
    
        return min(strong_neighbors)

   
    return min(neighbors, key=lambda g: (len(edges[g]), g))


def remove_from_tables(node: int,
                       edges: Dict[int, Set[int]],
                       strong_edges: Dict[int, Set[int]]) -> None:

    if node in edges:
        del edges[node]
    if node in strong_edges:
        del strong_edges[node]

    for neigh_set in edges.values():
        neigh_set.discard(node)
    for strong_set in strong_edges.values():
        strong_set.discard(node)


def edge_recombination_crossover(p1: list[int], p2: list[int]) -> list[int]:
    edges, strong_edges = build_edge_table(p1, p2)

    start = choose_start_node(edges)
    offspring = [start]
    current = start

    n = len(p1)

   
    while len(offspring) < n:
        
        next_node = choose_next_node(current, edges, strong_edges)

       
        if next_node is None:
           
            candidates = [g for g in edges.keys() if g != current]
            if not candidates:
               
                break
            next_node = random.choice(candidates)

       
        remove_from_tables(current, edges, strong_edges)

        
        offspring.append(next_node)

        
        current = next_node

    return offspring


def split_routes(permutation: list[int],
                 distance_matrix: list[list[float]],
                 time_matrix: list[list[float]],
                 capacity: int = 4,
                 max_route_time: float | None = None,
                 fixed_cost_per_car: float = 50.0,
                 cost_per_km: float = 2.0) -> list[list[int]]:
    
    n = len(permutation)
   
    best_cost = [float("inf")] * (n + 1)  
    pred = [-1] * (n + 1)                 
    best_cost[0] = 0.0

    
    for j in range(1, n + 1):
        load = 0
        time_sum = 0.0
        dist_sum = 0.0
        last_node = 0  

        
        for i in range(j, 0, -1):
            customer = permutation[i - 1]
            load += 1
            if load > capacity:
                break

            
            travel_time = time_matrix[last_node][customer]
            time_sum += travel_time
            if max_route_time is not None and time_sum > max_route_time:
                break

            
            dist_sum += distance_matrix[last_node][customer]

            
            route_cost = fixed_cost_per_car + cost_per_km * dist_sum
            total_cost = best_cost[i - 1] + route_cost

            if total_cost < best_cost[j]:
                best_cost[j] = total_cost
                pred[j] = i - 1

            last_node = customer

    
    routes: list[list[int]] = []
    idx = n
    while idx > 0:
        start = pred[idx]
        if start == -1:
            
            start = 0
        segment = permutation[start:idx]   
        route = [0] + segment             
        routes.append(route)
        idx = start

    routes.reverse()  
    return routes


def compute_total_cost(routes: list[list[int]],
                       distance_matrix: list[list[float]],
                       fixed_cost_per_car: float,
                       cost_per_km: float) -> float:

    total_cost = 0.0

    for route in routes:
        route_distance = 0.0
        for i in range(len(route) - 1):
            a = route[i]
            b = route[i + 1]
            route_distance += distance_matrix[a][b]

        if len(route) > 1:
            total_cost += fixed_cost_per_car

        total_cost += cost_per_km * route_distance

    return total_cost


def evaluate_solution(permutation: list[int],
                      distance_matrix: list[list[float]],
                      time_matrix: list[list[float]],
                      capacity: int,
                      max_route_time: float | None,
                      fixed_cost_per_car: float,
                      cost_per_km: float) -> float:

    routes = split_routes(
    permutation,
    distance_matrix=distance_matrix,
    time_matrix=time_matrix,
    capacity=capacity,
    max_route_time=max_route_time,
    fixed_cost_per_car=fixed_cost_per_car,
    cost_per_km=cost_per_km
)


    total_cost = compute_total_cost(routes,
                                    distance_matrix=distance_matrix,
                                    fixed_cost_per_car=fixed_cost_per_car,
                                    cost_per_km=cost_per_km)
    return total_cost


def tournament_selection(population: list[list[int]],
                         fitnesses: list[float],
                         tournament_size: int = 3) -> list[int]:

    n = len(population)
    indices = random.sample(range(n), tournament_size)
    best_idx = min(indices, key=lambda idx: fitnesses[idx])
    return population[best_idx][:]



def run_ga(distance_matrix: list[list[float]],
           time_matrix: list[list[float]],
           num_customers: int,
           capacity: int,
           max_route_time: float | None,
           fixed_cost_per_car: float,
           cost_per_km: float,
           pop_size: int = 50,
           generations: int = 200,
           crossover_rate: float = 0.9,
           mutation_rate: float = 0.1,
           tournament_size: int = 3) -> tuple[list[int], float]:

    customers = list(range(1, num_customers + 1))

    population: list[list[int]] = []
    fitnesses: list[float] = []

    for _ in range(pop_size):
        chrom = customers[:]
        random.shuffle(chrom)
        population.append(chrom)
        fitnesses.append(
            evaluate_solution(chrom, distance_matrix, time_matrix, capacity,
                              max_route_time, fixed_cost_per_car, cost_per_km)
        )

    best_idx = min(range(pop_size), key=lambda i: fitnesses[i])
    best_chrom = population[best_idx][:]
    best_cost = fitnesses[best_idx]

    for _ in range(generations):
        new_population: list[list[int]] = [best_chrom[:]]

        while len(new_population) < pop_size:
            p1 = tournament_selection(population, fitnesses, tournament_size)
            p2 = tournament_selection(population, fitnesses, tournament_size)

            if random.random() < crossover_rate:
                child = edge_recombination_crossover(p1, p2)
            else:
                child = p1[:]

            swap_mutation(child, mutation_rate)
            new_population.append(child)

        population = new_population
        fitnesses = [
            evaluate_solution(chrom, distance_matrix, time_matrix,
                              capacity, max_route_time, fixed_cost_per_car,
                              cost_per_km)
            for chrom in population
        ]

        gen_best_idx = min(range(pop_size), key=lambda i: fitnesses[i])
        gen_best_cost = fitnesses[gen_best_idx]

        if gen_best_cost < best_cost:
            best_cost = gen_best_cost
            best_chrom = population[gen_best_idx][:]

    return best_chrom, best_cost




