def tsplib_euc2d_matrix(coords: List[Point]) -> List[List[float]]:
    
    n = len(coords)
    dist = [[0.0] * n for _ in range(n)]
    for i in range(n):
        x1, y1 = coords[i]
        for j in range(n):
            x2, y2 = coords[j]
            dx = x1 - x2
            dy = y1 - y2
            dij = math.sqrt(dx * dx + dy * dy)
            dist[i][j] = int(dij + 0.5)
    return dist


