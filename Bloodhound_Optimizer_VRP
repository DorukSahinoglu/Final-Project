import random
import math
from dataclasses import dataclass, field
from typing import List, Tuple, Optional, Dict, Set

Point = Tuple[float, float]
Route = List[int]
Route_matrix = List[Route]
Distance_matrix = List[List[float]]
Edge = Tuple[int, int]

@dataclass
class Vehicle:
    vehicle_id: int
    capacity: float
    cost_per_km: float
    speed: float = 1.0

@dataclass
class SolutionState:
    routes: Route_matrix
    vehicle_ids: List[int]
    route_loads: List[float]
    route_distances: List[float]
    route_costs: List[float]
    total_cost: float
    feasible: bool

@dataclass
class HCVRPProblem:
    coords: List[Point]
    demands: List[float]
    vehicles: List[Vehicle]
    dist: Distance_matrix = field(init = False)
    n_nodes: int = field(init = False)
    customer_ids: List[int] = field(init = False)

    def __post_init__(self):

        self.n_nodes = len(self.coords)
        self.customer_ids = list(range(1, self.n_nodes))

        if len(self.demands) != self.n_nodes:

            raise ValueError("Demands Coords ile aynı olmalı")
        
        if self.demands[0] != 0:

            raise ValueError("Depot demand 0 olmalı")
        
        if len(self.vehicles) == 0:

            raise ValueError("En az 1 araç tanımlanmalı")
        
        self.dist = self.build_tsplib_euc2d_matrix(self.coords)

    @staticmethod
    def build_tsplib_euc2d_matrix(coords: List[Point]) -> Distance_matrix:

        n = len(coords)
        dist = [[0.0] * n for _ in range(n)]

        for i in range(n):
            x1, y1 = coords[i]
            for j in range(n):

                x2, y2 = coords[j]
                dx = x1 - x2
                dy = y1 - y2
                dij = math.sqrt(dx*dx + dy*dy)
                dist[i][j] = int(dij + 0.5) 
        return dist
    
    def route_distance(self, route: Route) -> float:

        total = 0.0
        for i in range(len(route) - 1):
            total += self.dist[route[i]][route[i + 1]]
        
        return total
    
    def route_load(self, route: Route) -> float:

        total = 0.0
        for node in route:
            total += self.demands[node]
        
        return total
    
    def customers_covered_once(self, routes: Route_matrix) -> bool:

        seen = []
        for route in routes:
            for node in route:
                if node != 0:
                    seen.append(node)
        
        seen_sorted = sorted(seen)
        return seen_sorted == self.customer_ids
    

def normalize_route(route: Route) -> Route:

    core = [node for node in route if node != 0]
    return [0] + core + [0]

def clone_routes(routes: Route_matrix) -> Route_matrix:

    return [r[:] for r in routes]

def extract_customers(routes: Route_matrix) -> List[int]:

    customers = []
    for route in routes:
        for node in route:

            if node != 0:
                customers.append(node)
            
    return customers

def route_has_duplicate_customer(route: Route) -> bool:

    customers = [node for node in route if node != 0]
    return len(customers) != len(set(customers))

def build_edge_signature_from_routes(routes: Route_matrix) -> Set[Edge]:

    sig: Set[Edge] = set()

    for route in routes:
        nr = normalize_route(route)

        for i in range(len(nr) - 1):
            a, b = nr[i], nr[i + 1]
            edge = (a, b) if a < b else (b, a)
            sig.add(edge)

    return sig


def max_region_similarity_routes(routes: Route_matrix, closed_regions: List[Set[Edge]]) -> float:

    if not closed_regions:
        return 0.0
    
    current_sig = build_edge_signature_from_routes(routes)
    best_sim = 0.0

    for sig in closed_regions:
        if not sig:
            continue

        inter = current_sig & sig
        sim = len(inter) / len(sig)
        if sim > best_sim:
            best_sim = sim

    return best_sim

def evaluate_solution(
        problem: HCVRPProblem,
        routes: Route_matrix,
        vehicle_ids: List[int],
        infeasible_penalty: float = 1e12
) -> SolutionState:
    
    if len(routes) != len(vehicle_ids):
        raise ValueError("Routes ve vehicle id uzunluğu aynı olmalı")
    
    normalized_routes: Route_matrix = [normalize_route(r) for r in routes]

    route_loads: List[float] = []
    route_distances: List[float] = []
    route_costs: List[float] = []

    feasible = True

    for route, v_id in zip(normalized_routes, vehicle_ids):

        if v_id < 0 or v_id >= len(problem.vehicles):

            raise ValueError(f"Gecersiz vehicle id: {v_id}")
        
        vehicle = problem.vehicles[v_id]

        if route_has_duplicate_customer(route):

            feasible = False

        load = problem.route_load(route)
        dist = problem.route_distance(route)
        cost = dist * vehicle.cost_per_km

        if load > vehicle.capacity:
            
            feasible = False

        route_loads.append(load)
        route_distances.append(dist)
        route_costs.append(cost)
    
    all_customers = extract_customers(normalized_routes)
    if sorted(all_customers) != problem.customer_ids:
        feasible = False

    total_cost = sum(route_costs)
    if not feasible:
        total_cost += infeasible_penalty

    return SolutionState(       
        routes = normalized_routes,
        vehicle_ids = vehicle_ids[:],
        route_loads = route_loads,
        route_distances = route_distances,
        route_costs = route_costs,
        total_cost = total_cost,
        feasible = feasible
    )

def get_vehicle_by_id(problem: HCVRPProblem, vehicle_id: int) -> Vehicle:

    return problem.vehicles[vehicle_id]

def route_core(route: Route) -> List[int]:

    return [node for node in route if node != 0]

def can_append_customer_to_route(
        problem: HCVRPProblem,
        route: Route,
        customer: int,
        vehicle: Vehicle
) -> bool:
    
    current_load = problem.route_load(normalize_route(route))
    return current_load + problem.demands[customer] <= vehicle.capacity

def cheapest_feasible_unused_vehicle(
        problem: HCVRPProblem,
        required_load: float,
        used_vehicle_ids: Set[int]
) -> Optional[int]:
    
    candidates = []

    for v in problem.vehicles:
        if v.vehicle_id in used_vehicle_ids:

            continue

        if v.capacity >= required_load:

            candidates.append(v)

    if not candidates:
        return None
    
    candidates.sort(key = lambda v: (v.cost_per_km, v.capacity))
    return candidates[0].vehicle_id


def best_append_position_by_distance(
        problem: HCVRPProblem,
        route: Route,
        customer: int
) -> int:
    
    nr = normalize_route(route)
    best_pos = 1
    best_delta = float("inf")

    for i in range(len(nr) - 1):

        a = nr[i]
        b = nr[i + 1]
        old_cost = problem.dist[a][b]
        new_cost = problem.dist[a][customer] + problem.dist[customer][b]

        delta = new_cost - old_cost

        insert_pos = i + 1
        if delta < best_delta:
            best_delta = delta
            best_pos = insert_pos

    return best_pos

def generate_feasible_solution(
        problem: HCVRPProblem,
        sort_by_demands_desc: bool = True,
        randomize_ties: bool = True,
        max_attempts: int = 50
) -> SolutionState:
    
    customer_list = problem.customer_ids[:]

    for _ in range(max_attempts):

        customers = customer_list[:]

        if sort_by_demands_desc:
            if randomize_ties:
                random.shuffle(customers)

            customers.sort(key = lambda c: problem.demands[c], reverse = True)

        else:
            random.shuffle(customers)


        routes: Route_matrix = []
        vehicle_ids: List[int] = []
        used_vehicle_ids: Set[int] = set()

        success = True

        for customer in customers:
            placed = False

            route_indices = list(range(len(routes)))
            random.shuffle(route_indices)

            best_choice = None
            best_choice_delta = float("inf")

            for r_idx in route_indices:
                v_id = vehicle_ids[r_idx]
                vehicle = get_vehicle_by_id(problem, v_id)
                route = routes[r_idx]

                if not can_append_customer_to_route(problem, route, customer, vehicle):

                    continue

                nr = normalize_route(route)
                pos = best_append_position_by_distance(problem, nr, customer)

                a = nr[pos - 1]
                b = nr[pos]

                delta = (problem.dist[a][customer] + problem.dist[customer][b] - problem.dist[a][b])

                if delta < best_choice_delta:
                    best_choice_delta = delta
                    best_choice = (r_idx, pos)

            if best_choice is not None:

                r_idx, pos = best_choice
                nr = normalize_route(routes[r_idx])
                nr.insert(pos, customer)
                routes[r_idx] = nr
                placed = True

            if not placed:

                required_load = problem.demands[customer]
                new_vehicle_id = cheapest_feasible_unused_vehicle(
                    problem,
                    required_load = required_load,
                    used_vehicle_ids = used_vehicle_ids
                )

                if new_vehicle_id is None:

                    success = False
                    break

                new_route = [0, customer, 0]
                routes.append(new_route)
                vehicle_ids.append(new_vehicle_id)
                used_vehicle_ids.add(new_vehicle_id)
                placed = True

        if not success:

            continue
        
        state = evaluate_solution(problem, routes, vehicle_ids)

        if state.feasible:

            return state
    
    raise RuntimeError("Initial feasible solution uretilemedi")

@dataclass
class Wolf:
    problem: HCVRPProblem
    state: SolutionState
    best_state: SolutionState
    blood: float = 0.0

    quality_score: float = 0.0
    best_quality_score: float = 0.0

    delta_history: List[float] = field(default_factory = list)

    @classmethod
    def create_random(cls, problem: HCVRPProblem) -> "Wolf":

        init_state = generate_feasible_solution(problem)
        return cls(
            problem = problem,
            state = init_state,
            best_state = init_state,
            blood = 0.0,
            quality_score = 0.0,
            best_quality_score = 0.0,
            delta_history = []
        )
    
    def clone_state(self, state: SolutionState) -> SolutionState:

        return SolutionState(
            routes = clone_routes(state.routes),
            vehicle_ids = state.vehicle_ids[:],
            route_loads = state.route_loads[:],
            route_distances = state.route_distances[:],
            route_costs = state.route_costs[:],
            total_cost = state.total_cost,
            feasible = state.feasible
        )
    
    def update_if_better(self, candidate_state: SolutionState):

        if candidate_state.total_cost < self.state.total_cost:

            self.state = self.clone_state(candidate_state)

        if candidate_state.total_cost < self.best_state.total_cost:

            self.best_state = self.clone_state(candidate_state)


def initialize_wolves(problem: HCVRPProblem, num_wolves: int) -> List[Wolf]:

    wolves = []
    for _ in range(num_wolves):
        wolves.append(Wolf.create_random(problem))
    return wolves

def minmax_normalize_costs_to_quality(costs: List[float]) -> List[float]:

    if not costs:
        return []
    
    c_min = min(costs)
    c_max = max(costs)

    if abs(c_max - c_min) < 1e-12:

        return [1.0 for _ in costs]
    
    qualities = []

    for c in costs:

        q = (c_max - c) / (c_max - c_min)

        q = max(0.0, min(1.0, q))

        qualities.append(q)

    return qualities

def update_population_quality_scores(wolves: List[Wolf]):

    current_costs = [w.state.total_cost for w in wolves]

    current_qualities = minmax_normalize_costs_to_quality(current_costs)

    for w, q in zip(wolves, current_qualities):

        w.quality_score = q
    
    best_costs = [w.best_state.total_cost for w in wolves]
    best_qualities = minmax_normalize_costs_to_quality(best_costs)

    for w, q in zip(wolves, best_qualities):

        w.best_quality_score = q

def population_cost_stats(wolves: List[Wolf]) -> Tuple[float, float, float]:

    costs = [w.state.total_cost for w in wolves]
    c_min = min(costs)
    c_mean = sum(costs) / len(costs)
    c_max = max(costs)
    return c_min, c_mean, c_max

def robust_scale_from_history(values: List[float], fallback: float = 1.0) -> float:

    if not values:

        return fallback
    
    vals = sorted(abs(v) for v in values)

    m = len(vals)

    if m % 2 == 1:
        med = vals[m // 2]

    else:
        med = 0.5 * (vals[m // 2 - 1] + vals[m // 2])

    return max(med, 1e-9)

def register_delta_and_get_scaled_delta(wolf: Wolf, raw_delta: float, max_history: int = 50) -> float:

    wolf.delta_history.append(raw_delta)
    if len(wolf.delta_history) > max_history:

        wolf.delta_history.pop(0)

    scale = robust_scale_from_history(wolf.delta_history, fallback = 1.0)
    return raw_delta / scale


def clone_solution_state(state: SolutionState) -> SolutionState:
    return SolutionState(
        routes = clone_routes(state.routes),
        vehicle_ids = state.vehicle_ids[:],
        route_loads = state.route_loads[:],
        route_distances = state.route_distances[:],
        route_costs = state.route_costs[:],
        total_cost = state.total_cost,
        feasible = state.feasible
    )


def remove_empty_routes(
        routes: Route_matrix,
        vehicle_ids: List[int]
) -> Tuple[Route_matrix, List[int]]:
    
    new_routes = []
    new_vehicle_ids = []

    for route, v_id in zip(routes, vehicle_ids):

        nr = normalize_route(route)
        if len(route_core(nr)) == 0:

            continue

        new_routes.append(nr)
        new_vehicle_ids.append(v_id)

    return new_routes, new_vehicle_ids

def random_intra_route_2opt(
        problem: HCVRPProblem,
        state: SolutionState
) -> SolutionState:
    
    candidate = clone_solution_state(state)
    eligible = []

    for r_idx, route in enumerate(candidate.routes):

        core = route_core(route)
        if len(core) >= 4:
            eligible.append(r_idx)

    if not eligible:
        return candidate
    
    r_idx = random.choice(eligible)
    core = route_core(candidate.routes[r_idx])

    i = random.randint(0, len(core) - 2)
    k = random.randint(i + 1, len(core) - 1)

    new_core = core[:i] + core[i:k + 1][::-1] + core[k + 1:]

    candidate.routes[r_idx] = [0] + new_core + [0]

    return evaluate_solution(problem, candidate.routes, candidate.vehicle_ids)

def random_inter_route_relocate(
        problem: HCVRPProblem,
        state: SolutionState
) -> SolutionState:
    
    candidate = clone_solution_state(state)

    non_empty_indices = [
        i for i, r in enumerate(candidate.routes)
        if len(route_core(r)) >= 1
    ]

    if len(non_empty_indices) < 1:
        return candidate
    
    from_idx = random.choice(non_empty_indices)

    possible_to_indices = [i for i in range(len(candidate.routes)) if i != from_idx]

    if not possible_to_indices:
        return candidate
    
    to_idx = random.choice(possible_to_indices)

    from_core = route_core(candidate.routes[from_idx])
    to_core = route_core(candidate.routes[to_idx])

    if not from_core:
        return candidate
    
    cust_pos = random.randint(0, len(from_core) - 1)
    customer = from_core.pop(cust_pos)

    insert_pos = random.randint(0, len(to_core))
    to_core.insert(insert_pos, customer)

    candidate.routes[from_idx] = [0] + from_core + [0]
    candidate.routes[to_idx] = [0] + to_core + [0]

    candidate.routes, candidate.vehicle_ids =remove_empty_routes(candidate.routes, candidate.vehicle_ids)

    return evaluate_solution(problem, candidate.routes, candidate.vehicle_ids)

def random_inter_route_swap(
        problem: HCVRPProblem,
        state: SolutionState
) -> SolutionState:
    
    candidate = clone_solution_state(state)

    eligible = [
        i for i, r in enumerate(candidate.routes)
        if len(route_core(r)) >= 1
    ]

    if len(eligible) < 2:
        return candidate
    
    r1, r2 = random.sample(eligible, 2)

    core1 = route_core(candidate.routes[r1])
    core2 = route_core(candidate.routes[r2])

    p1 = random.randint(0, len(core1) - 1)
    p2 = random.randint(0, len(core2) - 1)

    core1[p1], core2[p2] = core2[p2], core1[p1]

    candidate.routes[r1] = [0] + core1 + [0]
    candidate.routes[r2] = [0] + core2 + [0]

    return evaluate_solution(problem, candidate.routes, candidate.vehicle_ids)

def random_intra_route_reinsert(
        problem: HCVRPProblem,
        state: SolutionState
) -> SolutionState:
    
    candidate = clone_solution_state(state)

    eligible = [
        i for i, r in enumerate(candidate.routes)
        if len(route_core(r)) >= 3
    ]

    if not eligible:
        return candidate
    
    r_idx = random.choice(eligible)
    core = route_core(candidate.routes[r_idx])

    i, j = random.sample(range(len(core)), 2)
    customer = core.pop(i)

    core.insert(j, customer)

    candidate.routes[r_idx] = [0] + core + [0]

    return evaluate_solution(problem, candidate.routes, candidate.vehicle_ids)

def random_vehicle_reassignment(
        problem: HCVRPProblem,
        state: SolutionState
) -> SolutionState:
    
    candidate= clone_solution_state(state)

    if len(candidate.routes) == 0:

        return candidate
    
    r_idx = random.randint(0, len(candidate.routes) - 1)
    current_v_id = candidate.vehicle_ids[r_idx]
    route = candidate.routes[r_idx]
    load = problem.route_load(route)

    used = set(candidate.vehicle_ids)
    unused_vehicles = []

    for v in problem.vehicles:

        if v.vehicle_id in used and v.vehicle_id != current_v_id:

            continue

        if v.capacity >= load and v.vehicle_id != current_v_id:

            unused_vehicles.append(v.vehicle_id)

    if not unused_vehicles:
            return candidate
        
    
    new_v_id = random.choice(unused_vehicles)
    candidate.vehicle_ids[r_idx] = new_v_id
    
    return evaluate_solution(problem, candidate.routes, candidate.vehicle_ids)
    
def propose_random_neighbor(
        problem: HCVRPProblem,
        state: SolutionState
) -> SolutionState:
    
    operators = [
        random_intra_route_2opt,
        random_inter_route_relocate,
        random_inter_route_swap,
        random_intra_route_reinsert,
        random_vehicle_reassignment
    ]

    op = random.choice(operators)

    return op(problem, state)

def select_alpha_index(wolves: List[Wolf]) -> int:

    best_idx = 0
    best_key = (
        wolves[0].blood,
        wolves[0].best_quality_score,
        -wolves[0].best_state.total_cost
    )

    for i in range(1, len(wolves)):

        key = (
            wolves[i].blood,
            wolves[i].best_quality_score,
            -wolves[i].best_state.total_cost
        )

        if key > best_key:
            best_key = key
            best_idx = i

    return best_idx

def try_accept_neighbor(
        wolf: Wolf,
        candidate_state: SolutionState,
        closed_regions: Optional[List[Set[Edge]]] = None,
        lambda_reg: float = 0.0,
        a: float = 1.5,
        b: float = 2.0,
        c: float = 1.0,
        b_par: float = 1.2,
        min_improve_gain: float = 0.10,
        quality_gain_weight: float = 0.50
        
) -> bool:
    
    old_cost = wolf.state.total_cost
    new_cost = candidate_state.total_cost
    raw_delta = new_cost - old_cost

    scaled_delta = register_delta_and_get_scaled_delta(wolf, raw_delta)

    region_pen = 0.0
    if closed_regions and lambda_reg > 0.0:

            sim = max_region_similarity_routes(candidate_state.routes, closed_regions)
            region_pen = lambda_reg * sim
    
    effective_delta = scaled_delta + region_pen

    if raw_delta <= 0:

        prev_quality = wolf.quality_score
        wolf.state = wolf.clone_state(candidate_state)

        if candidate_state.total_cost < wolf.best_state.total_cost:
            wolf.best_state = wolf.clone_state(candidate_state)

        improve_amount = old_cost - new_cost

        standardized_improve = max(0.0, -scaled_delta)
        blood_gain = min_improve_gain + standardized_improve + quality_gain_weight * prev_quality

        wolf.blood += blood_gain

        return True
    
    d = max(0.0, effective_delta)
    p_allow = math.exp(-a * (d**b))

    if random.random() > p_allow:

        return False
    
    penalty = c * (math.exp(b_par * d) - 1.0)

    if wolf.blood >= penalty:
        wolf.blood -= penalty
        if wolf.blood < 0.0:
            wolf.blood = 0.0

        wolf.state = wolf.clone_state(candidate_state)
        return True
    return False

def explore_one_step(
        wolf: Wolf,
        closed_regions: Optional[List[Set[Edge]]] = None,
        lambda_reg: float = 0.0,
        a: float = 1.5,
        b: float = 2.0,
        c: float = 1.0,
        b_par: float = 1.2
):
    
    candidate_state = propose_random_neighbor(wolf.problem, wolf.state)

    try_accept_neighbor(
        wolf = wolf,
        candidate_state = candidate_state,
        closed_regions = closed_regions,
        a = a,
        b = b,
        c = c,
        b_par = b_par
    )

def free_search_phase(
        wolves: List[Wolf],
        iterations_per_wolf: int = 200,
        closed_regions: Optional[List[Set[Edge]]] = None,
        lambda_reg: float = 0.0,
        a: float = 1.5,
        b: float = 2.0,
        c: float = 1.0,
        b_par: float = 1.2
):
    
    for _ in range(iterations_per_wolf):

        for wolf in wolves:

            explore_one_step(
                wolf = wolf,
                closed_regions = closed_regions,
                lambda_reg = lambda_reg,
                a = a,
                b = b,
                c = c,
                b_par = b_par
            )

        update_population_quality_scores(wolves)

def reset_wolves_for_new_hunt(
        wolves: List[Wolf],
        reserve_blood: float = 2.0,
        clear_history: bool = True
):
    for wolf in wolves:

        wolf.blood = reserve_blood
        if clear_history:
            wolf.delta_history.clear()

def flatten_customers_from_routes(routes: Route_matrix) -> List[int]:

    customers = []
    for route in routes:
        for node in route:
            if node != 0:
                customers.append(node)
    return customers

def build_customer_to_route_map(routes: Route_matrix) -> dict[int, int]:

    mapping = {}
    for r_idx, route in enumerate(routes):

        for node in route:

            if node != 0:
                mapping[node] = r_idx

    return mapping

def choose_best_insertion_position(
        problem: HCVRPProblem,
        route: Route,
        customer: int
) -> tuple[int, float]:
    
    nr = normalize_route(route)
    best_pos = 1
    best_delta = float("inf")

    for i in range(len(nr) - 1):

        a = nr[i]
        b = nr[i + 1]
        old_cost = problem.dist[a][b]
        new_cost = problem.dist[a][customer] + problem.dist[customer][b]
        delta = new_cost - old_cost

        if delta < best_delta:
            best_delta = delta
            best_pos = i + 1

    return best_pos, best_delta

def assign_best_feasible_vehicle_for_tour(
        problem: HCVRPProblem,
        route: Route,
        forbidden_vehicle_ids: Set[int]
) -> Optional[int]:
    
    load = problem.route_load(route)
    candidates = []

    for v in problem.vehicles:

        if v.vehicle_id in forbidden_vehicle_ids:
            continue
        if v.capacity >= load:
            route_dist = problem.route_distance(route)
            route_cost = route_dist * v.cost_per_km
            candidates.append((route_cost, v.capacity, v.vehicle_id))

    if not candidates:
        
        return None
    
    candidates.sort(key = lambda x: (x[0], x[1]))

    return candidates[0][2]

def remove_customers_from_routes(
        routes: Route_matrix,
        customers_to_remove: Set[int]
) -> Route_matrix:
    
    new_routes = []
    for route in routes:
        core = [node for node in route if node != 0 and node not in customers_to_remove]

        if core:

            new_routes.append([0] + core + [0])

    return new_routes

def alpha_guided_rebuild(
        problem: HCVRPProblem,
        base_state: SolutionState,
        alpha_state: SolutionState,
        inherit_frac: float = 0.35
) -> SolutionState:
    
    base_routes = clone_routes(base_state.routes)
    base_vehicle_ids = base_state.vehicle_ids[:]

    alpha_customers = flatten_customers_from_routes(alpha_state.routes)

    n_customers = len(alpha_customers)

    if n_customers == 0:

        return clone_solution_state(base_state)
    
    q = max(1, int(inherit_frac * n_customers))

    selected_customers = set(random.sample(alpha_customers, q))

    reduced_routes = remove_customers_from_routes(base_routes, selected_customers)
    reduced_vehicle_ids = []

    used_vehicle_ids: Set[int] = set()

    for route in reduced_routes:

        v_id = assign_best_feasible_vehicle_for_tour(problem, route, used_vehicle_ids)
        if v_id is None:
            return clone_solution_state(base_state)
        
        reduced_vehicle_ids.append(v_id)
        used_vehicle_ids.add(v_id)

    alpha_map = build_customer_to_route_map(alpha_state.routes)

    grouped: Dict[int, List[int]] = {}

    for c in selected_customers:

        r_idx = alpha_map[c]
        grouped.setdefault(r_idx, []).append(c)
    
    for alpha_r_idx, alpha_route in enumerate(alpha_state.routes):
        group = grouped.get(alpha_r_idx, [])
        if not group:
            continue

        ordered_group = [node for node in alpha_route if node in group]

        for customer in ordered_group:

            best_target = None
            best_delta = float("inf")

            for r_idx, route in enumerate(reduced_routes):

                vehicle = get_vehicle_by_id(problem, reduced_vehicle_ids[r_idx])

                load = problem.route_load(route)

                if load + problem.demands[customer] > vehicle.capacity:

                    continue

                pos, delta = choose_best_insertion_position(problem, route, customer)
                if delta < best_delta:
                    best_delta = delta
                    best_target = (r_idx, pos)

            if best_target is not None:

                r_idx, pos = best_target
                nr = normalize_route(reduced_routes[r_idx])
                nr.insert(pos, customer)
                reduced_routes[r_idx] = nr
                continue

            new_route = [0, customer, 0]
            new_v_id = assign_best_feasible_vehicle_for_tour(problem, new_route, used_vehicle_ids)

            if new_v_id is None:

                return clone_solution_state(base_state)
            
            reduced_routes.append(new_route)
            reduced_vehicle_ids.append(new_v_id)
            used_vehicle_ids.add(new_v_id)

    return evaluate_solution(problem, reduced_routes, reduced_vehicle_ids)

def ruin_and_rebuild_routes(
        problem: HCVRPProblem,
        state: SolutionState,
        ruin_frac: float = 0.20
) -> SolutionState:
    
    customers = flatten_customers_from_routes(state.routes)
    n = len(customers)

    if n <= 2:
        return clone_solution_state(state)
    
    q = max(1, int(ruin_frac * n))
    removed = set(random.sample(customers, q))

    routes = remove_customers_from_routes(state.routes, removed)
    vehicle_ids: List[int] = []
    used_vehicle_ids: Set[int] = set()

    for route in routes:
        v_id = assign_best_feasible_vehicle_for_tour(problem, route, used_vehicle_ids)
        if v_id is None:
            return clone_solution_state(state)
        
        vehicle_ids.append(v_id)
        used_vehicle_ids.add(v_id)

    removed_list = list(removed)
    random.shuffle(removed_list)

    for customer in removed_list:
        best_target = None
        best_delta = float("inf")

        for r_idx, route in enumerate(routes):

            vehicle = get_vehicle_by_id(problem, vehicle_ids[r_idx])

            load = problem.route_load(route)

            if load + problem.demands[customer] > vehicle.capacity:

                continue

            pos, delta =choose_best_insertion_position(problem, route, customer)

            if delta < best_delta:

                best_delta = delta
                best_target = (r_idx, pos)
        
        if best_target is not None:
            r_idx, pos = best_target
            nr = normalize_route(routes[r_idx])
            nr.insert(pos, customer)
            routes[r_idx] = nr
            continue

        new_route = [0, customer, 0]
        new_v_id = assign_best_feasible_vehicle_for_tour(problem, new_route, used_vehicle_ids)
        if new_v_id is None:

            return clone_solution_state(state)
        
        routes.append(new_route)
        vehicle_ids.append(new_v_id)
        used_vehicle_ids.add(new_v_id)
    return evaluate_solution(problem, routes, vehicle_ids)



def hunt_one_wolf_towards_alpha(
        wolf: Wolf,
        alpha_state: SolutionState,
        inherit_frac: float = 0.35,
        ruin_frac: float = 0.20,
        rr_repeats: int = 2
) -> SolutionState:
    
    current = alpha_guided_rebuild(
        problem = wolf.problem,
        base_state = wolf.state,
        alpha_state = alpha_state,
        inherit_frac = inherit_frac
    )

    best = current

    for _ in range(rr_repeats):

        candidate = ruin_and_rebuild_routes(
            problem = wolf.problem,
            state = best,
            ruin_frac = ruin_frac
        )
        if candidate.total_cost < best.total_cost:

            best = candidate

    return best

def hunt_around_alpha(
        wolves: List[Wolf],
        alpha_idx: int,
        inherit_frac: float = 0.35,
        ruin_frac: float = 0.20,
        rr_repeats: int = 2
) -> tuple[SolutionState, float]:
    
    alpha = wolves[alpha_idx]
    alpha_state = alpha.best_state

    hunt_best_state = alpha.clone_state(alpha_state)
    hunt_best_cost = alpha_state.total_cost

    for i, wolf in enumerate(wolves):

        if i == alpha_idx:

            continue
        
        candidate = hunt_one_wolf_towards_alpha(
            wolf = wolf,
            alpha_state = alpha_state,
            inherit_frac = inherit_frac,
            ruin_frac = ruin_frac,
            rr_repeats = rr_repeats
        )

        wolf.update_if_better(candidate)

        if candidate.total_cost < hunt_best_cost:

            hunt_best_state = alpha.clone_state(candidate)
            hunt_best_cost = candidate.total_cost

    alpha.update_if_better(hunt_best_state)

    update_population_quality_scores(wolves)

    return hunt_best_state, hunt_best_cost

def get_global_best_state(wolves: List[Wolf]) -> SolutionState:

    best = wolves[0].clone_state(wolves[0].best_state)
    for w in wolves[1:]:
        
        if w.best_state.total_cost < best.total_cost:

            best = w.clone_state(w.best_state)
    
    return best

def run_bloodhound_hcvrp(
        problem: HCVRPProblem,
        num_wolves: int = 12,
        num_hunts: int = 20,
        explore_iterations: int = 120,
        reserve_blood: float = 2.0,
        lambda_reg: float = 0.30,
        a: float = 1.5,
        b: float = 2.0,
        c: float = 1.0,
        b_par: float = 1.2,
        inherit_frac: float = 0.35,
        ruin_frac: float = 0.20,
        rr_repeats: int = 2,
        verbose: bool = True
) -> SolutionState:
    
    wolves = initialize_wolves(problem, num_wolves)

    update_population_quality_scores(wolves)

    global_best = get_global_best_state(wolves)

    closed_regions: List[Set[Edge]] = []

    if verbose:

        print("Initial best cost:", round(global_best.total_cost, 4))

    for hunt_idx in range(num_hunts):

        reset_wolves_for_new_hunt(
                wolves,
                reserve_blood = reserve_blood,
                clear_history = True
            )

        free_search_phase(
                wolves = wolves,
                iterations_per_wolf = explore_iterations,
                closed_regions = closed_regions,
                lambda_reg = lambda_reg,
                a = a,
                b = b,
                c = c,
                b_par = b_par
            )

        alpha_idx = select_alpha_index(wolves)

        hunt_best_state, hunt_best_cost = hunt_around_alpha(
                wolves = wolves,
                alpha_idx = alpha_idx,
                inherit_frac = inherit_frac,
                ruin_frac = ruin_frac,
                rr_repeats = rr_repeats
            )

        if hunt_best_cost < global_best.total_cost:

                global_best = wolves[alpha_idx].clone_state(hunt_best_state)

        sig = build_edge_signature_from_routes(hunt_best_state.routes)
        closed_regions.append(sig)

        update_population_quality_scores(wolves)

        if verbose:

                c_min, c_mean, c_max = population_cost_stats(wolves)

                print(
                f"Hunt {hunt_idx + 1}/{num_hunts} | "
                f"alpha={alpha_idx} | "
                f"hunt_best={hunt_best_cost:.4f} | "
                f"global_best={global_best.total_cost:.4f} | "
                f"pop_min={c_min:.4f} | "
                f"pop_mean={c_mean:.4f} | "
                f"pop_max={c_max:.4f} | "
                f"closed_regions={len(closed_regions)}"

            )
    return global_best
                

